}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Cat creation by measurement (Eqs. 5, 6)", "Section",ExpressionUUID->"975f28ed-9493-2f46-a2f3-d2d9d9708c2e"],

Cell["\<\
Projecting the ancilla onto |m> yields exactly |C_d^m(alpha)>. Fidelity \
should be 1.\
\>", "Text",ExpressionUUID->"3e3fc4d5-b0ee-ad45-bf33-be169666e300"],

Cell[CellGroupData[{

Cell["\<\
GeneralizedCD`GCDSetFockSize[50];
With[{d = 4, alpha = 2.0},
 Table[Module[{psi, proj, osc, nf = GeneralizedCD`GCDFockSize[]},
   psi = GeneralizedCD`GeneralizedCD[d, alpha] . Flatten[Outer[Times, \
GeneralizedCD`QuditXEigenstate[d, 0], GeneralizedCD`Vacuum[]]];
   proj = ArrayFlatten[{Table[Conjugate[GeneralizedCD`QuditXEigenstate[d, \
m][[s + 1]]] IdentityMatrix[nf], {s, 0, d - 1}]}];
   osc = proj . psi;
   m -> Abs[Conjugate[GeneralizedCD`LeggedCatState[d, m, alpha]] . \
(osc/Norm[osc])]^2], {m, 0, d - 1}]]\
\>", "Input",
 CellLabel->"In[17]:=",ExpressionUUID->"7d5dd277-c98c-4e49-ad85-4305bbd5ad97"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"0", "\[Rule]", "1.`"}], ",", 
   RowBox[{"1", "\[Rule]", "0.9999999999999998`"}], ",", 
   RowBox[{"2", "\[Rule]", "1.`"}], ",", 
   RowBox[{"3", "\[Rule]", "0.9999999999999996`"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9920812203910904`*^9},
 CellLabel->"Out[18]=",ExpressionUUID->"bd90b22c-babd-5440-a3d3-ec3604d16348"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. GKP stabilizer Kraus operators (Eqs. 8-11)", "Section",ExpressionUUID->"2a441291-5c8f-2049-9c07-fea705d66dbe"],

Cell["\<\
The d = 4 stabilizer Kraus operator M_j(beta) has three equivalent forms: the \
definition <j|CD_4(e^{i pi/4} sqrt2 beta)|m=0> (Eq. 8), Eq. 9, and Eq. 10. \
They agree exactly, satisfy POVM completeness, and the |j> basis diagonalizes \
the Hermitian observable of Eq. 11.\
\>", "Text",ExpressionUUID->"51b713e2-fcf4-3a40-9293-f17f074d1bc0"],

Cell[CellGroupData[{

Cell["\<\
beta = Sqrt[Pi]/Sqrt[2];
{
 \"Eq9 vs Eq10\" -> \
Chop@Max[Table[Max[Abs[GeneralizedCD`QuditStabilizerKraus[j, beta] - \
GeneralizedCD`QuditStabilizerKrausEq10[j]]], {j, 0, 3}]],
 \"POVM sum - I\" -> \
Chop@Max[Abs[Sum[ConjugateTranspose[GeneralizedCD`QuditStabilizerKraus[j, \
beta]].GeneralizedCD`QuditStabilizerKraus[j, beta], {j, 0, 3}] - \
IdentityMatrix[GeneralizedCD`GCDFockSize[]]]]
}\
\>", "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"865e3338-f808-c74b-8503-2ea237e90add"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\<\"Eq9 vs Eq10\"\>", "\[Rule]", "0"}], ",", 
   RowBox[{"\<\"POVM sum - I\"\>", "\[Rule]", "0"}]}], "}"}]], "Output",
 CellChangeTimes->{3.992081220425209*^9},
 CellLabel->"Out[20]=",ExpressionUUID->"63950905-44f6-6c46-83de-1a4de8ea2611"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* Eq. 11 is Hermitian and the |j> basis are its eigenvectors *)
H11 = GeneralizedCD`QuditHermitianObservable[];
{\"Hermitian\" -> (H11 == ConjugateTranspose[H11]), \"eigenvalues\" -> \
Chop[Eigenvalues[N[H11]]],
 \"eigen-residuals\" -> Table[Module[{v = GeneralizedCD`QuditMeasBasis[j, \
beta], hv}, hv = H11.v; Chop[Norm[hv - (Conjugate[v].hv/(Conjugate[v].v)) \
v]]], {j, 0, 3}]}\
\>", "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"4aec8e8c-bcbb-3a4e-837c-7effb503d196"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\<\"Hermitian\"\>", "\[Rule]", "True"}], ",", 
   RowBox[{"\<\"eigenvalues\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"3.`", ",", "2.0000000000000004`", ",", "1.`", ",", "0"}], 
     "}"}]}], ",", 
   RowBox[{"\<\"eigen-residuals\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.9920812204422665`*^9},
 CellLabel->"Out[23]=",ExpressionUUID->"138327d7-8d1e-be43-bfaa-0f451d20034e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. GKP stabilization from vacuum (Fig. 2d)", "Section",ExpressionUUID->"03bae3fb-fdbf-604f-b9aa-38792b3433b8"],

Cell["\<\
The qudit d = 4 sharpen-trim protocol drives the vacuum toward the GKP \
manifold. Because a single CD_4 addresses both quadratures, one qudit round \
costs 2 CD operations vs 4 for the qubit protocol, and the qudit reaches a \
target <S> at fewer CD operations.\
\>", "Text",ExpressionUUID->"8cc36c41-9142-a541-93c2-21d6e8ad75a3"],

Cell[CellGroupData[{

Cell["\<\
GeneralizedCD`GCDSetFockSize[70];
qud = GeneralizedCD`RunQuditStabilization[30];
ListLinePlot[{{#[[1]], (#[[2]] + #[[3]])/2} & /@ qud, {#[[1]], #[[4]]/20.} & \
/@ qud},
 PlotStyle -> {Red, Gray}, Frame -> True, PlotRange -> {0, 1},
 FrameLabel -> {\"number of CD operations\", \"value\"},
 PlotLegends -> {\"<S> (qudit sharpen+trim)\", \"<n>/20 (bounded energy)\"}, \
ImageSize -> 520]\
\>", "Input",
 CellLabel->"In[24]:=",ExpressionUUID->"c0881885-17e7-1f40-a17a-16edf33ca5fb"],

